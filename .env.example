# Router service configuration
ROUTER_PORT=3000        # host port (auto-adjusted if occupied)
NODE_ENV=development

# Ollama (context compressor)
OLLAMA_PORT=11434       # host port (auto-adjusted if occupied)
OLLAMA_URL=http://ollama:11434
OLLAMA_API_KEY=please-set-a-secret
OLLAMA_MODEL=mistral
COMPRESSOR_TOKEN_THRESHOLD=3000

# Remote model providers
CLAUDE_API_KEY=please-set-a-secret
CLAUDE_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=please-set-a-secret
OPENAI_BASE_URL=https://api.openai.com
OPENAI_DEFAULT_MODEL=gpt-4o
GEMINI_API_KEY=please-set-a-secret
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_DEFAULT_MODEL=gemini-1.5-flash
GEMINI_DAILY_TOKEN_LIMIT=1500000   # free tier: ~1.5M tokens/day

# Groq (free tier — https://console.groq.com)
GROQ_API_KEY=please-set-a-secret
GROQ_BASE_URL=https://api.groq.com
GROQ_DEFAULT_MODEL=llama3-8b-8192
GROQ_DAILY_TOKEN_LIMIT=500000      # free tier: ~500K tokens/day

# Quota tracker (proactive daily-limit guard, avoids 429s before they happen)
QUOTA_TRACKER_PATH=./data/quota.json

# Routing rules
DEFAULT_REMOTE_MODEL=claude-3.5-sonnet
LOCAL_MODEL_THRESHOLD=800
SIMULATION_COMMAND_FLAG=/simulate

# Ollama request timeout in milliseconds (model inference on CPU can be slow)
OLLAMA_REQUEST_TIMEOUT_MS=120000
SUMMARY_INPUT_MAX_TOKENS=300
SUMMARY_OUTPUT_MAX_TOKENS=150

# Rate limit retry
RATE_LIMIT_MAX_RETRIES=3      # max retry attempts on 429 (0 = no retry)
RATE_LIMIT_MAX_WAIT_MS=60000  # ceiling for any single wait (ms)

# Observability
LOG_LEVEL=info
METRICS_ENABLED=true
CACHE_TTL_SECONDS=120
