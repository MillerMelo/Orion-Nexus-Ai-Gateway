#!/usr/bin/env bash
# Conventional Commits enforcement
# Format: type(scope): description
# Types: feat, fix, docs, refactor, test, chore, ci, perf, style, revert

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

# Ignore merge commits and fixup/squash commits
if echo "$MSG" | grep -qE "^(Merge |fixup! |squash! )"; then
  exit 0
fi

PATTERN="^(feat|fix|docs|refactor|test|chore|ci|perf|style|revert)(\([a-z0-9_/-]+\))?: .{1,100}$"

# Check only the first line (subject)
SUBJECT=$(echo "$MSG" | head -1)

if ! echo "$SUBJECT" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Commit rechazado: mensaje no sigue Conventional Commits"
  echo ""
  echo "  Formato requerido:"
  echo "    type(scope): descripción"
  echo ""
  echo "  Tipos válidos:"
  echo "    feat fix docs refactor test chore ci perf style revert"
  echo ""
  echo "  Ejemplos válidos:"
  echo "    feat(classifier): add semantic intent detection"
  echo "    fix(proxy): handle timeout on openrouter fallback"
  echo "    chore(deps): update express to 4.21"
  echo ""
  echo "  Tu mensaje:"
  echo "    $SUBJECT"
  echo ""
  exit 1
fi

exit 0
